<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<!-- Owner: Person C. RV-01/02. -->
<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.theater.reservation.ui.SeatSelectController"
      spacing="12" prefWidth="900" prefHeight="700">
  <padding>
    <Insets top="16" right="16" bottom="16" left="16"/>
  </padding>
  <HBox spacing="8">
    <Button fx:id="cancelButton" text="戻る" onAction="#onCancelClicked"/>
    <Label text="座席選択"/>
  </HBox>
  <Label fx:id="screeningLabel"/>
  <Label fx:id="userLabel"/>
  <Label text="SCREEN" maxWidth="Infinity"
         style="-fx-alignment: center; -fx-background-color: #eeeeee; -fx-padding: 8;"/>
  <GridPane fx:id="seatGrid" hgap="8" vgap="8"/>
  <HBox spacing="12">
    <Label text="AVAILABLE" style="-fx-text-fill: #2e7d32;"/>
    <Label text="SELECTED" style="-fx-text-fill: #1565c0;"/>
    <Label text="HOLD" style="-fx-text-fill: #f9a825;"/>
    <Label text="SOLD" style="-fx-text-fill: #757575;"/>
    <Label text="BLOCKED" style="-fx-text-fill: #212121;"/>
  </HBox>
  <Label fx:id="errorLabel" style="-fx-text-fill: #c62828;"/>
  <Button fx:id="reserveButton" text="予約する" maxWidth="Infinity"
          onAction="#onReserveClicked"/>
</VBox>
