<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<!-- Owner: Person C. RV-01/02. -->
<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.theater.reservation.ui.SeatSelectController"
      spacing="12" prefWidth="900" prefHeight="700">
  <padding>
    <Insets top="16" right="16" bottom="16" left="16"/>
  </padding>
  <HBox spacing="8">
    <Button fx:id="cancelButton" text="戻る" onAction="#onCancelClicked"/>
    <Label text="座席選択"/>
  </HBox>
  <Label fx:id="screeningLabel"/>
  <Label fx:id="userLabel"/>
  <Label text="Seat Select (TODO)"/>
</VBox>
