<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<!-- Owner: Person A. ID-02 Register / ID-04 UI. -->
<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.theater.identity.ui.RegisterController"
      spacing="12" alignment="CENTER" prefWidth="400" prefHeight="420">
  <padding>
    <Insets top="32" right="32" bottom="32" left="32"/>
  </padding>
  <Label text="新規登録" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

  <VBox spacing="4">
    <Label text="氏名"/>
    <TextField fx:id="nameField" promptText="山田 太郎"/>
  </VBox>

  <VBox spacing="4">
    <Label text="メールアドレス"/>
    <TextField fx:id="emailField" promptText="taro@example.com"/>
  </VBox>

  <VBox spacing="4">
    <Label text="パスワード (8 文字以上)"/>
    <PasswordField fx:id="passwordField" promptText="********"/>
  </VBox>

  <Label fx:id="errorLabel" style="-fx-text-fill: red;" wrapText="true"/>
  <Label fx:id="successLabel" style="-fx-text-fill: green;" wrapText="true"/>

  <Button fx:id="registerButton" text="登録" maxWidth="Infinity"
          onAction="#onRegisterClicked" defaultButton="true"/>

  <HBox spacing="4" alignment="CENTER">
    <Label text="既にアカウントをお持ちの方は"/>
    <Hyperlink text="ログイン" onAction="#onLoginLinkClicked"/>
  </HBox>
</VBox>
