<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<!-- Owner: Person C. OR-01/02. -->
<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.theater.ordering.ui.CheckoutController"
      spacing="12" prefWidth="600" prefHeight="500">
  <padding>
    <Insets top="16" right="16" bottom="16" left="16"/>
  </padding>
  <Label text="チェックアウト"/>
  <Label fx:id="totalAmountLabel" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
  <Label text="座席"/>
  <ListView fx:id="seatList" prefHeight="280"/>
  <Label fx:id="errorLabel" style="-fx-text-fill: #c62828;"/>
  <Button fx:id="payButton" text="決済する" maxWidth="Infinity"
          onAction="#onPayClicked"/>
</VBox>
